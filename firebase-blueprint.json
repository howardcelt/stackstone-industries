{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents an agricultural or processed food product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "unit": { "type": "string" },
        "moq": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "stock": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "shippingAddress": { "type": "object" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Wholesale, Export, or Distributor inquiry.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["wholesale", "distributor", "export", "general"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "name", "email", "message"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog article or news update.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of all Stackston products."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer purchase records."
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Business leads from contact forms."
    },
    "blog": {
      "schema": "BlogPost",
      "description": "Articles and news."
    }
  }
}
