rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidProduct(p) {
      return p.name is string && p.name.size() > 0 && p.name.size() <= 200 &&
             p.description is string && p.description.size() <= 2000 &&
             p.price is number && p.price >= 0 &&
             p.category is string &&
             (!('stock' in p) || p.stock is number);
    }

    function isValidOrder(o) {
      return o.userId == request.auth.uid &&
             o.items is list && o.items.size() > 0 &&
             o.totalAmount is number && o.totalAmount >= 0 &&
             o.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             o.createdAt == request.time;
    }

    function isValidInquiry(i) {
      return i.name is string && i.name.size() > 0 &&
             i.email is string && i.email.size() > 0 &&
             i.type in ['wholesale', 'distributor', 'export', 'general'] &&
             i.status == 'new' &&
             i.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if (isAdmin() || (isOwner(existing().userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      existing().status == 'pending' && incoming().status == 'cancelled'));
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /blog/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
